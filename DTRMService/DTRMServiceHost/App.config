<?xml version="1.0" encoding="utf-8" ?>
<configuration>    
  
  <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
    </startup>  
  <system.serviceModel>
    <services>
       
      <service name="DTRMService.DTRMService" behaviorConfiguration="mexBehaviour">
        
        <endpoint address="DTRMService" binding="basicHttpBinding" contract="DTRMService.IDTRMService" >
          <identity>
            <userPrincipalName value="*"/>
          </identity>
        </endpoint>
        <endpoint address="DTRMService" binding="netTcpBinding" contract="DTRMService.IDTRMService">
          <identity>
            <userPrincipalName value="*"/>
          </identity>
        </endpoint>
        <endpoint address="mex" binding="mexHttpBinding" contract="IMetadataExchange">
          <identity>
            <userPrincipalName value="*"/>
          </identity>
        </endpoint>
        <host>
          <baseAddresses>
            <add baseAddress="http://192.168.0.155:8080/DTRMService"/>
            <add baseAddress="net.tcp://192.168.0.155:8090/DTRMService"/>
          </baseAddresses>
        </host>
      </service>
    </services>
    <behaviors>
      
      <serviceBehaviors>
        <behavior name="mexBehaviour">
          <serviceMetadata httpGetEnabled="true"  httpsGetEnabled="true"/>
        </behavior>
        
      </serviceBehaviors>
    </behaviors>
    
  </system.serviceModel>
  
</configuration>