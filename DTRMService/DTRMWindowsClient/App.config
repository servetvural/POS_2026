<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="BasicHttpBinding_IDTRMService" />
            </basicHttpBinding>
            <netTcpBinding>
                <binding name="NetTcpBinding_IDTRMService" />
            </netTcpBinding>
        </bindings>
        <client>
            <endpoint address="http://localhost:8080/DTRMService" binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_IDTRMService" contract="DTRMService.IDTRMService"
                name="BasicHttpBinding_IDTRMService" />
            <endpoint address="net.tcp://localhost:8090/DTRMService" binding="netTcpBinding"
                bindingConfiguration="NetTcpBinding_IDTRMService" contract="DTRMService.IDTRMService"
                name="NetTcpBinding_IDTRMService">
                <identity>
                    <userPrincipalName value="SERVETASUS\servet" />
                </identity>
            </endpoint>
        </client>
    </system.serviceModel>
</configuration>